# ── Required ────────────────────────────────────────────────────────────────
# Hardcover API bearer token — Settings → API → Generate token
HARDCOVER_TOKEN=

# Anthropic API key — https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Audiobookshelf (optional) ────────────────────────────────────────────────
# Base URL for the ABS API. For Docker: use your Docker bridge gateway IP
# (e.g. http://192.168.x.x:13378) rather than localhost from inside the container.
ABS_URL=

# ABS API token — Settings → Users → your account → API Token
ABS_TOKEN=

# ── App settings ─────────────────────────────────────────────────────────────
# Host port for the bookclub web UI (default: 8585)
BOOKCLUB_PORT=8585

# Timezone for displayed timestamps (default: UTC)
TZ=UTC

# Claude model used for recommendation generation (default: claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Advanced / overrides ─────────────────────────────────────────────────────
# SQLite DB path inside the container (default: /data/bookclub.db)
# DB_PATH=/data/bookclub.db

# ABS SQLite DB path inside the container (default: /abs_config/absdatabase.sqlite)
# ABS_DB_PATH=/abs_config/absdatabase.sqlite
